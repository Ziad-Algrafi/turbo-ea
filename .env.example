# ── Required ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_use_a_strong_password
SECRET_KEY=changeme_generate_with_python_c_import_secrets_print_secrets_token_urlsafe_64

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_DB=turboea
POSTGRES_USER=turboea
POSTGRES_PORT=5432

# ── Backend ───────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENVIRONMENT=production

# ── Port exposed on the host (Dokploy will map this) ─────────────────────────
HOST_PORT=8920

# ── CORS — set to your Dokploy domain after first deploy ─────────────────────
ALLOWED_ORIGINS=http://localhost:8920

# ── Demo data (first run only) ────────────────────────────────────────────────
# SEED_DEMO=true
# SEED_BPM=true
# SEED_PPM=true

# ── AI (optional) ─────────────────────────────────────────────────────────────
# AI_PROVIDER_URL=http://ollama:11434
# AI_MODEL=gemma3:4b
# AI_AUTO_CONFIGURE=true

# ── SMTP (optional) ───────────────────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_FROM=noreply@yourdomain.com
# SMTP_TLS=true

# ── NVD API key (optional) ────────────────────────────────────────────────────
# NVD_API_KEY=
